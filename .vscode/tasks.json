{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: build example, active file",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--target",
				"${fileBasenameNoExtension}",
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
		},
