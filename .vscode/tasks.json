{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: build example, active file",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--target",
				"${fileBasenameNoExtension}",
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
		},
		{
			"type": "cppbuild",
			"label": "C/C++: build GLRenderer",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--target",
				"GLRenderer",
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
		},
		{
			"type": "cppbuild",
			"label": "C/C++: build VKRenderer",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--target",
				"VKRenderer",
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
		},
		{
			"type": "cppbuild",
			"label": "C/C++: build ShitRenderer",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--target",
				"ShitRenderer",
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
		},
		{
			"type": "cppbuild",
			"label": "C/C++: clean",
			"command": "cmake",
			"args": [
				"--build",
				"build",
				"--target",
				"clean",
				"-v"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
		},
		{
			"type": "cppbuild",
			"label": "C/C++: config project ninja x64 debug",
			"command": "cmake",
			"args": [
				"-B",
				"build",
				"-DCMAKE_TOOLCHAIN_FILE=D:\\Workspace\\3rdparty\\vcpkg\\scripts\\buildsystems\\vcpkg.cmake",
				"-G",
				"Ninja",
				"-DCMAKE_C_COMPILER='gcc;'",
				"-DCMAKE_CXX_COMPILER='g++;'",
				"-DCMAKE_BUILD_TYPE=Debug"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
		},
		{
			"type": "cppbuild",
			"label": "C/C++: config project ninja x64 release",
			"command": "cmake",
			"args": [
				"-B",
				"build",
				"-DCMAKE_TOOLCHAIN_FILE=D:\\Workspace\\3rdparty\\vcpkg\\scripts\\buildsystems\\vcpkg.cmake",
				"-G",
				"Ninja",
				"-DCMAKE_C_COMPILER='gcc;'",
				"-DCMAKE_CXX_COMPILER='g++;'",
				"-DCMAKE_BUILD_TYPE=Release"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
		},
	]
}