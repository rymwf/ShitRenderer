				"-B",
				"build",
				"-DCMAKE_TOOLCHAIN_FILE=D:\\Workspace\\3rdparty\\vcpkg\\scripts\\buildsystems\\vcpkg.cmake",
				"-G",
				"Ninja",
				//"-DCMAKE_C_COMPILER='C:/Program Files (x86)/Microsoft Visual Studio/2019/Community/VC/Tools/Llvm/x64/bin/clang-cl.exe'",
